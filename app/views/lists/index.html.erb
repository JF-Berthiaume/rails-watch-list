<div class="container py-5">
  <div class="d-flex align-items-center justify-content-between mb-5">
    <h1 class="fw-bold" style="font-family: 'Georgia', serif;">Mes Collections</h1>
    <%= link_to new_list_path, class: "btn btn-success shadow-sm" do %>
      <i class="fa-solid fa-plus"></i> Créer une liste
    <% end %>
  </div>

  <div class="row">
    <% @lists.each do |list| %>
      <div class="col-12 col-sm-6 col-md-4 mb-4">
        <%# Le lien englobe toute la carte pour un clic plus facile %>
        <%= link_to list_path(list), class: "text-decoration-none" do %>
          <div class="list-card shadow-sm" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.8)), url('<%= list.movies.any? ? list.movies.first.poster_url : "https://images.unsplash.com/photo-1489599849927-2ee91cede3ba" %>');">
            <div class="list-card-content">
              <h3 class="text-white m-0"><%= list.name %></h3>
              <p class="text-warning m-0 small"><%= list.movies.count %> films</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
